# COCO Environment Configuration
# This file documents the variables COCO uses. In a normal install you do NOT
# edit this by hand — scripts/install.sh generates /opt/coco/.env for you.
# Permissions on the real file must be 600.

# Security — generated automatically (openssl rand -hex 32)
SECRET_KEY=change-me-min-32-chars

# Database / cache (created by the installer)
DATABASE_URL=postgresql://coco:PASSWORD@localhost/coco
DB_URL=postgresql://coco:PASSWORD@localhost/coco
REDIS_URL=redis://localhost:6379

# Proxmox API (the COCO control VM talks to its own Proxmox host)
PROXMOX_HOST=127.0.0.1
PROXMOX_USER=root@pam
PROXMOX_PASSWORD=your-proxmox-root-password
PROXMOX_NODE=pve

# COCO web service
COCO_IP=10.0.0.10
COCO_PORT=443
SSL_CERT=/opt/coco/ssl/coco.crt
SSL_KEY=/opt/coco/ssl/coco.key

# Repo location on the control VM
COCO_REPO_DIR=/opt/coco/repo

# Guacamole (created by the installer)
GUACAMOLE_URL=http://localhost:8080/guacamole
