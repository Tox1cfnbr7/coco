# COCO Environment Configuration
# Copy this file to /opt/coco/.env and fill in your values
# Permissions: chmod 600 /opt/coco/.env

# Security — generate with: openssl rand -hex 32
SECRET_KEY=change-me-to-a-random-string-min-32-chars

# Proxmox API connection
PROXMOX_HOST=192.168.118.1
PROXMOX_USER=root@pam
PROXMOX_PASSWORD=your-proxmox-password
PROXMOX_NODE=pve

# COCO VM network
COCO_IP=192.168.118.133
COCO_PORT=8080

# Game network (managed by COCO — do not change unless you know what you are doing)
GAME_BRIDGE=br-game
GAME_NETWORK=10.10.0.0/16
AD_VLAN=10
WEBAPP_VLAN=20
DB_VLAN=30
